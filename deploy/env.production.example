# Production environment for a DigitalOcean droplet.
# Copy to /opt/bglib/.env.local on the server (chmod 600).

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Public URL — must match your Cloudflare subdomain (HTTPS)
NEXT_PUBLIC_APP_URL=https://bglib.csst.rocks

# Web Push (generate: npx web-push generate-vapid-keys)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@csst.rocks

# Email (optional)
RESEND_API_KEY=
EMAIL_FROM="BgLib <notifications@csst.rocks>"

# BGG (required for search/import — register at https://boardgamegeek.com/applications)
BGG_API_TOKEN=

# GameUPC (optional — barcode scan on Add Game; register at https://gameupc.com)
GAMEUPC_API_TOKEN=

# Loan reminder cron — random secret, used by systemd timer / curl
CRON_SECRET=change-me-to-a-long-random-string

# Server bind (optional — defaults to 0.0.0.0:3000)
BIND_HOST=0.0.0.0
PORT=3000
