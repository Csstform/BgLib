NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Optional: for sending push notifications from server
# Generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

# Optional: Supabase service role key (required for push, email, and cron)
SUPABASE_SERVICE_ROLE_KEY=

# Optional: BoardGameGeek API token (if required by BGG)
BGG_API_TOKEN=

# Email via Resend (https://resend.com)
RESEND_API_KEY=
EMAIL_FROM=BgLib <notifications@yourdomain.com>

# App URL for email links and cron
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Cron job authentication (set a random secret, pass as Bearer token)
CRON_SECRET=
