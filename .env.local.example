NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Optional: for sending push notifications from server
# Generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

# Optional: Supabase service role key (recommended for push notifications)
# Without this, push uses the anon key which may have RLS limitations
SUPABASE_SERVICE_ROLE_KEY=

# Optional: BoardGameGeek API token (if required by BGG)
BGG_API_TOKEN=
